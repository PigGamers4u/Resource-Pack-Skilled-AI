{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "waterwake:boat_wake",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/boat_wake"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 18
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "offset": [0, 0, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(1.8, 2.6)"
      },
      "minecraft:particle_motion_parametric": {
        "relative_position": [
          "variable.wake_x * (1.0 - variable.particle_age / variable.particle_lifetime) * 1.4 + variable.particle_random_1 * 0.12",
          "math.random(-0.03, 0.03)",
          "variable.wake_z * (1.0 - variable.particle_age / variable.particle_lifetime) * 1.4 + variable.particle_random_2 * 0.12"
        ]
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0, 360)",
        "rotation_rate": "math.random(-80, 80)"
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.25 * (1.0 - variable.particle_age / variable.particle_lifetime * 0.6)",
          "0.09 * (1.0 - variable.particle_age / variable.particle_lifetime * 0.5)"
        ],
        "facing_camera_mode": "direction_y",
        "uv": {
          "texture_width": 32,
          "texture_height": 16,
          "uv": [0, 0],
          "uv_size": [32, 16]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "gradient": {
            "0.0": [0.92, 0.98, 1.0, 0.75],
            "0.4": [0.78, 0.90, 1.0, 0.55],
            "1.0": [0.65, 0.82, 1.0, 0.0]
          },
          "interpolant": "variable.particle_age / variable.particle_lifetime"
        }
      }
    }
  }
}